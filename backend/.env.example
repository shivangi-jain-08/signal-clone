# Copy this file to .env and fill in values before running the server.

# SQLite database URL (relative to backend/)
DATABASE_URL=sqlite+aiosqlite:///./signal.db

# JWT signing secret — generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-32-plus-random-chars

# JWT algorithm
ALGORITHM=HS256

# Token lifetime in days
ACCESS_TOKEN_EXPIRE_DAYS=7

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["http://localhost:3000"]

# Show /docs and /redoc (set to false in production)
SHOW_DOCS=true

# Media upload directory (relative path)
MEDIA_DIR=./media

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
